---
export const prerender = false;
import { hasStoredPassword, generateFirstRunPassword, setPassword } from '../lib/auth.js';

// Already have a password (e.g. reload) — go to sign in
if (hasStoredPassword()) {
  return Astro.redirect('/login');
}

const generatedPassword = generateFirstRunPassword();
setPassword(generatedPassword);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>First run – Speedarr</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #1a1a2e; color: #eee; }
      .card { background: #16213e; padding: 2rem; border-radius: 8px; width: 100%; max-width: 480px; }
      h1 { margin-top: 0; font-size: 1.5rem; }
      .password-box { background: #0f3460; padding: 1rem; border-radius: 4px; font-family: monospace; word-break: break-all; margin: 1rem 0; font-size: 0.95rem; }
      .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 1.25rem 0; }
      button, .btn { padding: 0.5rem 1rem; border-radius: 4px; font-size: 0.95rem; cursor: pointer; text-decoration: none; display: inline-block; border: none; background: #e94560; color: #fff; }
      button:hover, .btn:hover { opacity: 0.9; }
      .btn-secondary { background: #0f3460; }
      .hint { font-size: 0.9rem; color: #94a3b8; margin-top: 1.5rem; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>First run</h1>
      <p>Your dashboard password has been generated. Copy it or download it now; you will need it to sign in.</p>
      <p class="password-box" id="password-display">{generatedPassword}</p>
      <div class="actions">
        <button type="button" id="copy-btn">Copy password</button>
        <a href="#" id="download-btn" class="btn">Download as .txt</a>
        <a href="/login" class="btn btn-secondary">Continue to sign in</a>
      </div>
      <p class="hint" id="copy-hint" aria-live="polite"></p>
    </div>
    <script define:vars={{ generatedPassword }}>
      const passwordDisplay = document.getElementById('password-display');
      const copyBtn = document.getElementById('copy-btn');
      const downloadBtn = document.getElementById('download-btn');
      const copyHint = document.getElementById('copy-hint');

      copyBtn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(generatedPassword);
          copyHint.textContent = 'Copied to clipboard.';
          copyHint.style.color = '#86efac';
        } catch {
          copyHint.textContent = 'Copy failed; select and copy the password above.';
          copyHint.style.color = '#fca5a5';
        }
      });

      downloadBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const blob = new Blob(['Speedarr dashboard password\n\n' + generatedPassword + '\n'], { type: 'text/plain' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'speedarr-password.txt';
        a.click();
        URL.revokeObjectURL(a.href);
        copyHint.textContent = 'Download started.';
        copyHint.style.color = '#86efac';
      });
    </script>
  </body>
</html>
