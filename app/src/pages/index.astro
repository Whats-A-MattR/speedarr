---
export const prerender = false;
import { getResults, getLatestResult, getAgents, getLatestGluetunStatus } from '../lib/db.js';
import { getServices } from '../lib/config-file.js';
import { startCron } from '../lib/cron.js';

startCron();
const agentIdParam = Astro.url.searchParams.get('agent_id') ?? undefined;
const agents = getAgents();
const latest = getLatestResult(agentIdParam ?? undefined);
const results = getResults(100, undefined, agentIdParam ?? undefined).reverse();
const gluetunServices = getServices().filter((service) => service.type === 'gluetun' && service.enabled);
const gluetunOverview = gluetunServices.map((service) => ({
  id: service.id,
  name: service.name,
  status: getLatestGluetunStatus(service.id),
}));
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Speedarr – Dashboard</title>
    <script is:inline define:vars={{ results, latest, agents }}>
      window.__SPEEDARR_DATA__ = { results, latest, agents: agents || [] };
    </script>
  </head>
  <body>
    <div id="app">
      <header>
        <h1>Speedarr</h1>
        <nav>
          <a href="/">Dashboard</a> · <a href="/history">History</a> · <a href="/services">Services</a> · <a href="/settings">Settings</a>
          <form method="post" action="/api/auth/logout" style="display:inline; margin-left: 1rem;">
            <button type="submit">Sign out</button>
          </form>
        </nav>
      </header>
      <main>
        <section class="toolbar">
          <div class="filter-row">
            <label for="agent-filter">Filter by agent</label>
            <select id="agent-filter">
              <option value="">All agents</option>
              {agents.map((a) => (
                <option value={a.agent_id}>{a.agent_name}</option>
              ))}
            </select>
          </div>
          <button type="button" id="test-now-btn" class="btn-primary">Test now</button>
        </section>

        <section class="agents-section">
          <h2>Agents</h2>
          <ul class="agents-list">
            {agents.length === 0 ? (
              <li>No agents yet (run a test to see this node).</li>
            ) : (
              agents.map((a) => (
                <li><a href={`/?agent_id=${encodeURIComponent(a.agent_id)}`}>{a.agent_name}</a> <span class="agent-id">({a.agent_id})</span></li>
              ))
            )}
          </ul>
        </section>

        <section class="gluetun-section">
          <div class="gluetun-header">
            <h2>VPN Services</h2>
            <a class="btn-secondary btn-sm" href="/services">Manage Services</a>
          </div>
          {gluetunOverview.length === 0 ? (
            <p class="gluetun-empty">No enabled Gluetun services configured.</p>
          ) : (
            <table class="vpn-table">
              <thead>
                <tr>
                  <th>Service</th>
                  <th>Status</th>
                  <th>Public IP</th>
                  <th>Last Check</th>
                </tr>
              </thead>
              <tbody>
                {gluetunOverview.map((row) => (
                  <tr>
                    <td>{row.name}</td>
                    <td>
                      {row.status ? (
                        <span class={`vpn-status ${row.status.vpn_status === 'running' ? 'ok' : 'warn'}`}>{row.status.vpn_status}</span>
                      ) : (
                        <span class="vpn-status">unknown</span>
                      )}
                    </td>
                    <td>{row.status?.public_ip || '—'}</td>
                    <td>{row.status ? new Date(row.status.timestamp).toLocaleString() : '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </section>

        <section id="latest-section" class="latest">
          {latest ? (
            <>
              <h2>Latest result</h2>
              <p class="ip">Public IP: <span id="latest-ip">{latest.external_ip ?? 'unknown'}</span></p>
              <p class="stat download"><span id="latest-download">—</span> <span>Mbps down</span></p>
              <p class="stat upload"><span id="latest-upload">—</span> <span>Mbps up</span></p>
              <p class="stat latency"><span id="latest-latency">—</span> <span>latency</span></p>
              <p class="time" id="latest-time"></p>
            </>
          ) : (
            <>
              <h2>No results yet</h2>
              <p>Speed tests run on a schedule, or click "Test now" to run one.</p>
            </>
          )}
        </section>

        <section class="chart-section">
          <h2>Speed over time</h2>
          <canvas id="chart" width="800" height="300"></canvas>
        </section>
      </main>

      <div id="test-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-labelledby="modal-title">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
          <h3 id="modal-title">Run speed test</h3>
          <p id="modal-message">Run a speed test on this node now?</p>
          <div class="modal-actions">
            <button type="button" id="modal-cancel">Cancel</button>
            <button type="button" id="modal-run">Run</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      import { Chart, registerables } from 'chart.js';
      Chart.register(...registerables);

      const data = window.__SPEEDARR_DATA__;
      let chartInstance = null;

      function renderLatest(latest) {
        const downEl = document.getElementById('latest-download');
        const upEl = document.getElementById('latest-upload');
        const latEl = document.getElementById('latest-latency');
        const timeEl = document.getElementById('latest-time');
        const ipEl = document.getElementById('latest-ip');
        if (!latest) {
          if (downEl) downEl.textContent = '—';
          if (upEl) upEl.textContent = '—';
          if (latEl) latEl.textContent = '—';
          if (timeEl) timeEl.textContent = '';
          if (ipEl) ipEl.textContent = '—';
          return;
        }
        if (downEl) downEl.textContent = latest.download_mbps.toFixed(2);
        if (upEl) upEl.textContent = latest.upload_mbps.toFixed(2);
        if (latEl) latEl.textContent = latest.latency_ms != null ? `${latest.latency_ms.toFixed(0)} ms` : '—';
        if (timeEl) timeEl.textContent = new Date(latest.timestamp).toLocaleString();
        if (ipEl) ipEl.textContent = latest.external_ip ?? 'unknown';
      }

      function renderChart(results) {
        const canvas = document.getElementById('chart');
        const ctx = canvas?.getContext('2d');
        if (!ctx) return;
        if (chartInstance) chartInstance.destroy();
        if (!results.length) return;
        const labels = results.map((r) => new Date(r.timestamp).toLocaleString());
        chartInstance = new Chart(ctx, {
          type: 'line',
          data: {
            labels,
            datasets: [
              { label: 'Download (Mbps)', data: results.map((r) => r.download_mbps), borderColor: '#4ade80', tension: 0.2, fill: true },
              { label: 'Upload (Mbps)', data: results.map((r) => r.upload_mbps), borderColor: '#60a5fa', tension: 0.2, fill: true },
            ],
          },
          options: { responsive: true, scales: { y: { beginAtZero: true } } },
        });
      }

      renderLatest(data.latest);
      renderChart(data.results ?? []);

      const agentFilter = document.getElementById('agent-filter');
      if (agentFilter && data.agents?.length) {
        const current = new URLSearchParams(window.location.search).get('agent_id') ?? '';
        agentFilter.value = current;
        agentFilter.addEventListener('change', () => {
          const v = agentFilter.value;
          window.location.href = v ? `/?agent_id=${encodeURIComponent(v)}` : '/';
        });
      }

      const modal = document.getElementById('test-modal');
      const modalMessage = document.getElementById('modal-message');
      const modalRun = document.getElementById('modal-run');
      const modalCancel = document.getElementById('modal-cancel');
      const testNowBtn = document.getElementById('test-now-btn');

      function openModal() {
        if (!modal || !modalMessage || !modalRun) return;
        modal.classList.remove('hidden');
        modal.setAttribute('aria-hidden', 'false');
        modalMessage.textContent = 'Run a speed test on this node now?';
        modalRun.textContent = 'Run';
        modalRun.disabled = false;
      }

      function closeModal() {
        if (!modal) return;
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
      }

      testNowBtn?.addEventListener('click', openModal);
      modalCancel?.addEventListener('click', closeModal);
      modal?.querySelector('.modal-backdrop')?.addEventListener('click', closeModal);

      modalRun?.addEventListener('click', async () => {
        if (!modalRun || !modalMessage || modalRun.disabled) return;
        modalRun.disabled = true;
        modalMessage.textContent = 'Running speed test...';
        try {
          const res = await fetch('/api/test-now', { method: 'POST', credentials: 'same-origin' });
          const json = await res.json();
          if (!res.ok) {
            modalMessage.textContent = 'Error: ' + (json.error || res.statusText);
            modalRun.disabled = false;
            modalRun.textContent = 'Run';
            return;
          }
          const r = json.result;
          modalMessage.textContent = `Done: ${r.download_mbps.toFixed(2)} Mbps down, ${r.upload_mbps.toFixed(2)} Mbps up, latency ${r.latency_ms != null ? r.latency_ms.toFixed(0) : 'n/a'} ms`;
          modalRun.textContent = 'Close';
          modalRun.disabled = false;
          modalRun.onclick = () => { closeModal(); window.location.reload(); };
          data.latest = r;
          data.results = [{ ...r, id: 0 }, ...(data.results || []).slice(0, 99)];
          renderLatest(data.latest);
          renderChart(data.results);
        } catch (err) {
          modalMessage.textContent = 'Error: ' + (err instanceof Error ? err.message : String(err));
          modalRun.disabled = false;
          modalRun.textContent = 'Run';
        }
      });
    </script>

    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
      header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: #1e293b; border-bottom: 1px solid #334155; }
      header h1 { margin: 0; font-size: 1.25rem; }
      nav a { color: #94a3b8; text-decoration: none; margin-right: 0.5rem; }
      nav a:hover { color: #fff; }
      nav button { background: #334155; color: #94a3b8; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; cursor: pointer; font-size: 0.9rem; }
      nav button:hover { background: #475569; color: #fff; }
      main { padding: 2rem; max-width: 900px; margin: 0 auto; }
      .toolbar { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
      .filter-row { display: flex; align-items: center; gap: 0.5rem; }
      .filter-row label { color: #94a3b8; font-size: 0.9rem; }
      .filter-row select { background: #1e293b; border: 1px solid #334155; color: #e2e8f0; padding: 0.35rem 0.75rem; border-radius: 4px; }
      .btn-primary { background: #16a34a; color: #fff; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; font-weight: 500; }
      .btn-primary:hover { background: #15803d; }
      .btn-secondary { background: #334155; color: #e2e8f0; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; cursor: pointer; text-decoration: none; }
      .btn-secondary:hover { background: #475569; }
      .btn-sm { padding: 0.25rem 0.5rem; font-size: 0.85rem; }
      .agents-section, .gluetun-section { background: #1e293b; padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; }
      .agents-section h2, .gluetun-section h2 { margin: 0 0 0.5rem 0; font-size: 1rem; color: #94a3b8; }
      .agents-list { margin: 0; padding-left: 1.25rem; }
      .agents-list a { color: #60a5fa; }
      .agents-list .agent-id { color: #64748b; font-size: 0.85rem; }
      .gluetun-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; }
      .gluetun-empty { color: #94a3b8; }
      .vpn-table { width: 100%; border-collapse: collapse; }
      .vpn-table th, .vpn-table td { text-align: left; padding: 0.45rem 0.3rem; border-bottom: 1px solid #334155; font-size: 0.9rem; }
      .vpn-status.ok { color: #22c55e; }
      .vpn-status.warn { color: #fbbf24; }
      .latest { background: #1e293b; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; }
      .latest h2 { margin-top: 0; font-size: 1.1rem; color: #94a3b8; }
      .stat { font-size: 1.5rem; font-weight: 600; margin: 0.5rem 0; }
      .stat span { font-size: 0.9rem; font-weight: 400; color: #94a3b8; margin-left: 0.25rem; }
      .time { font-size: 0.85rem; color: #64748b; margin-top: 0.5rem; }
      .chart-section { background: #1e293b; padding: 1.5rem; border-radius: 8px; }
      .chart-section h2 { margin-top: 0; font-size: 1.1rem; color: #94a3b8; }
      .modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 1rem; }
      .modal.hidden { display: none; }
      .modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
      .modal-content { position: relative; background: #1e293b; padding: 1.5rem; border-radius: 8px; max-width: 400px; width: 100%; border: 1px solid #334155; }
      .modal-content h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; }
      .modal-content p { margin: 0 0 1rem 0; color: #94a3b8; }
      .modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
      .modal-actions button { background: #334155; color: #e2e8f0; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; }
      .modal-actions button:hover { background: #475569; }
      .modal-actions button:last-child { background: #16a34a; color: #fff; }
      .modal-actions button:last-child:hover { background: #15803d; }
      .modal-actions button:disabled { opacity: 0.6; cursor: not-allowed; }
    </style>
  </body>
</html>
