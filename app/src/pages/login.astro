---
export const prerender = false;
const error = Astro.url.searchParams.get('error');
const message = error === 'missing' ? 'Please enter a password.' : error === 'invalid' ? 'Invalid password.' : null;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Login – Speedarr</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #1a1a2e; color: #eee; }
      .card { background: #16213e; padding: 2rem; border-radius: 8px; width: 100%; max-width: 360px; }
      h1 { margin-top: 0; font-size: 1.5rem; }
      input { width: 100%; padding: 0.75rem; margin: 0.5rem 0; border: 1px solid #0f3460; border-radius: 4px; background: #0f3460; color: #eee; font-size: 1rem; }
      button { width: 100%; padding: 0.75rem; margin-top: 0.5rem; background: #e94560; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
      button:hover { opacity: 0.9; }
      .error { color: #e94560; font-size: 0.9rem; margin-top: 0.5rem; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Speedarr</h1>
      <p>Sign in to the dashboard.</p>
      <form method="post" action="/api/auth/login">
        <input type="password" name="password" placeholder="Password" autofocus />
        <button type="submit">Sign in</button>
      </form>
      {message && <p class="error">{message}</p>}
    </div>
  </body>
</html>
