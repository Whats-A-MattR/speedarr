---
export const prerender = false;
import { getNodes, getLatestResult } from '../lib/db.js';
import { startCron } from '../lib/cron.js';
import { getAgentIdentity } from '../lib/config.js';

startCron();
const { agentId: localAgentId, agentName: localAgentName } = getAgentIdentity();
const localLatest = getLatestResult(localAgentId);
const nodes = getNodes();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Nodes – Speedarr</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
      header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: #1e293b; border-bottom: 1px solid #334155; }
      header h1 { margin: 0; font-size: 1.25rem; }
      nav a { color: #94a3b8; text-decoration: none; margin-right: 0.5rem; }
      nav a:hover { color: #fff; }
      nav button { background: #334155; color: #94a3b8; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; cursor: pointer; font-size: 0.9rem; }
      nav button:hover { background: #475569; color: #fff; }
      main { padding: 2rem; max-width: 900px; margin: 0 auto; }
      .form-section { background: #1e293b; padding: 1.25rem; border-radius: 8px; margin-bottom: 2rem; }
      .form-section h2 { margin-top: 0; }
      .form-row { margin-bottom: 0.75rem; }
      .form-row label { display: inline-block; min-width: 6rem; color: #94a3b8; }
      .form-row input { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.4rem 0.6rem; border-radius: 4px; width: 100%; max-width: 20rem; }
      button.btn { background: #3b82f6; color: #fff; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; }
      button.btn:hover { background: #2563eb; }
      button.btn-sm { padding: 0.25rem 0.5rem; font-size: 0.85rem; }
      button.btn-danger { background: #dc2626; }
      button.btn-danger:hover { background: #b91c1c; }
      button.btn-secondary { background: #334155; color: #94a3b8; }
      button.btn-secondary:hover { background: #475569; color: #fff; }
      table { width: 100%; border-collapse: collapse; background: #1e293b; border-radius: 8px; overflow: hidden; }
      th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid #334155; }
      th { background: #0f172a; color: #94a3b8; font-weight: 500; }
      tr:last-child td { border-bottom: none; }
      .actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .badge { font-size: 0.75rem; padding: 0.2rem 0.5rem; border-radius: 4px; }
      .badge-blocked { background: #7f1d1d; color: #fca5a5; }
      .badge-active { background: #14532d; color: #86efac; }
      .msg { padding: 0.5rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
      .msg.err { background: #7f1d1d; color: #fca5a5; }
      .msg.ok { background: #14532d; color: #86efac; }
      .hidden { display: none; }
      .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 100; }
      .modal-backdrop.hidden { display: none; }
      .modal { background: #1e293b; padding: 1.5rem; border-radius: 8px; min-width: 320px; max-width: 90vw; }
      .modal h3 { margin-top: 0; }
      .modal .form-row { margin-bottom: 1rem; }
      .modal .form-row label { display: block; margin-bottom: 0.25rem; }
      .modal .form-row .hint { font-size: 0.85rem; color: #94a3b8; margin-top: 0.25rem; }
      .modal-actions { display: flex; gap: 0.5rem; margin-top: 1.25rem; }
      .modal-msg { margin-top: 0.75rem; font-size: 0.9rem; }
      .modal-msg.err { color: #fca5a5; }
      .modal-msg.ok { color: #86efac; }
    </style>
  </head>
  <body>
    <header>
      <h1>Speedarr</h1>
      <nav>
        <a href="/">Dashboard</a> · <a href="/history">History</a> · <a href="/nodes">Nodes</a> · <a href="/settings">Settings</a>
        <form method="post" action="/api/auth/logout" style="display:inline; margin-left: 1rem;">
          <button type="submit">Sign out</button>
        </form>
      </nav>
    </header>
    <main>
      <h2>Nodes</h2>
      <p>Add remote nodes (same code, <code>MODE=node</code>). Trigger tests from here; results appear on the dashboard.</p>
      <div class="form-section">
        <h3>Add node</h3>
        <form id="add-node-form">
          <div class="form-row">
            <label for="node-id">ID</label>
            <input type="text" id="node-id" name="id" placeholder="e.g. home-router" pattern="[a-zA-Z0-9_-]+" required />
          </div>
          <div class="form-row">
            <label for="node-name">Name</label>
            <input type="text" id="node-name" name="name" placeholder="e.g. Home" required />
          </div>
          <div class="form-row">
            <label for="node-address">Address</label>
            <input type="url" id="node-address" name="base_url" placeholder="http://192.168.1.1:3000" required />
          </div>
          <div class="form-row">
            <label for="node-api-key">API key</label>
            <input type="password" id="node-api-key" name="api_key" placeholder="Node's SPEEDARR_API_KEY" required />
          </div>
          <button type="submit" class="btn">Add node</button>
        </form>
      </div>
      <div id="msg" class="msg hidden" role="status"></div>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>ID</th>
            <th>Address</th>
            <th>Last IP</th>
            <th>Last seen</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr data-node-id="_local">
            <td class="node-name">{localAgentName}</td>
            <td><code>{localAgentId}</code></td>
            <td><code>This server</code></td>
            <td>{localLatest?.external_ip ?? '—'}</td>
            <td>{localLatest?.timestamp ? new Date(localLatest.timestamp).toLocaleString() : '—'}</td>
            <td><span class="badge badge-active">Active</span></td>
            <td class="actions">
              <button type="button" class="btn btn-sm test-btn test-local-btn">Test now</button>
            </td>
          </tr>
          {nodes.map((n) => (
            <tr data-node-id={n.id}>
              <td class="node-name">{n.name}</td>
              <td><code>{n.id}</code></td>
              <td><code>{n.base_url}</code></td>
              <td>{n.last_external_ip ?? '—'}</td>
              <td>{n.last_seen_at ? new Date(n.last_seen_at).toLocaleString() : '—'}</td>
              <td><span class="badge badge-active">Active</span></td>
              <td class="actions">
                <button type="button" class="btn btn-sm btn-secondary intervals-btn" data-id={n.id} data-name={n.name}>Intervals</button>
                <button type="button" class="btn btn-sm btn-secondary rename-btn" data-id={n.id} data-name={n.name}>Rename</button>
                <button type="button" class="btn btn-sm btn-danger remove-btn" data-id={n.id} data-name={n.name}>Remove</button>
                <button type="button" class="btn btn-sm test-btn" data-id={n.id}>Test now</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </main>
    <div id="intervals-modal" class="modal-backdrop hidden" aria-hidden="true">
      <div class="modal">
        <h3 id="intervals-modal-title">Intervals</h3>
        <div class="form-row">
          <label for="intervals-speed">Speed test interval (minutes)</label>
          <input type="number" id="intervals-speed" min="1" max="1440" value="360" />
        </div>
        <div class="form-row" id="intervals-reporting-row">
          <label>Reporting to</label>
          <p id="intervals-reporting-list" class="hint">Load to see dashboards this node posts results to. Enrolled automatically when added.</p>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" id="intervals-load-btn">Load</button>
          <button type="button" class="btn" id="intervals-save-btn">Save</button>
          <button type="button" class="btn btn-secondary" id="intervals-close-btn">Close</button>
        </div>
        <div id="intervals-modal-msg" class="modal-msg hidden"></div>
      </div>
    </div>
    <script define:vars={{ nodes: nodes }}>
      const addForm = document.getElementById('add-node-form');
      const msgEl = document.getElementById('msg');
      function showMsg(text, isError) {
        msgEl.textContent = text;
        msgEl.classList.remove('hidden', 'err', 'ok');
        msgEl.classList.add(isError ? 'err' : 'ok');
      }
      addForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('node-id').value.trim();
        const name = document.getElementById('node-name').value.trim();
        const base_url = document.getElementById('node-address').value.trim().replace(/\/$/, '');
        const api_key = document.getElementById('node-api-key').value;
        try {
          const r = await fetch('/api/nodes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, name, base_url, api_key }),
          });
          const data = await r.json();
          if (!r.ok) {
            showMsg(data.error || 'Failed to add node', true);
            return;
          }
          window.location.reload();
        } catch (err) {
          showMsg(err.message || 'Request failed', true);
        }
      });
      document.querySelectorAll('.rename-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          const current = btn.dataset.name;
          const name = prompt('New name:', current);
          if (name === null || name.trim() === '') return;
          try {
            const r = await fetch(`/api/nodes/${encodeURIComponent(id)}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name: name.trim() }),
            });
            if (!r.ok) {
              const data = await r.json();
              alert(data.error || 'Failed');
              return;
            }
            const row = document.querySelector(`tr[data-node-id="${id}"] .node-name`);
            if (row) row.textContent = name.trim();
            btn.dataset.name = name.trim();
          } catch (err) {
            alert(err.message || 'Request failed');
          }
        });
      });
      document.querySelectorAll('.remove-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          const name = btn.dataset.name || id;
          if (!confirm(`Remove node "${name}"? This cannot be undone.`)) return;
          try {
            const r = await fetch(`/api/nodes/${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!r.ok) {
              const data = await r.json();
              showMsg(data.error || 'Failed to remove node', true);
              return;
            }
            window.location.reload();
          } catch (err) {
            showMsg(err?.message || 'Request failed', true);
          }
        });
      });
      document.querySelector('.test-local-btn')?.addEventListener('click', async () => {
        const btn = document.querySelector('.test-local-btn');
        if (btn.disabled) return;
        btn.disabled = true;
        btn.textContent = 'Running…';
        try {
          const r = await fetch('/api/test-now', { method: 'POST', credentials: 'same-origin' });
          const data = await r.json();
          if (!r.ok) {
            showMsg(data.error || 'Test failed', true);
          } else {
            showMsg('Test completed.', false);
            window.location.reload();
          }
        } catch (err) {
          showMsg(err?.message || 'Request failed', true);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Test now';
        }
      });
      document.querySelectorAll('.test-btn:not(.test-local-btn)').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (btn.disabled) return;
          const id = btn.dataset.id;
          btn.disabled = true;
          btn.textContent = 'Running…';
          try {
            const r = await fetch(`/api/nodes/${encodeURIComponent(id)}/test`, { method: 'POST' });
            const data = await r.json();
            if (!r.ok) {
              showMsg(data.error || 'Test failed', true);
            } else {
              showMsg('Test completed.', false);
              window.location.reload();
            }
          } catch (err) {
            showMsg(err?.message || 'Request failed', true);
          } finally {
            btn.disabled = false;
            btn.textContent = 'Test now';
          }
        });
      });

      const intervalsModal = document.getElementById('intervals-modal');
      const intervalsTitle = document.getElementById('intervals-modal-title');
      const intervalsSpeed = document.getElementById('intervals-speed');
      const intervalsLoadBtn = document.getElementById('intervals-load-btn');
      const intervalsSaveBtn = document.getElementById('intervals-save-btn');
      const intervalsCloseBtn = document.getElementById('intervals-close-btn');
      const intervalsModalMsg = document.getElementById('intervals-modal-msg');
      let intervalsNodeId = null;

      function showIntervalsMsg(text, isError) {
        intervalsModalMsg.textContent = text;
        intervalsModalMsg.classList.remove('hidden', 'err', 'ok');
        intervalsModalMsg.classList.add(isError ? 'err' : 'ok');
      }

      const intervalsReportingList = document.getElementById('intervals-reporting-list');

      document.querySelectorAll('.intervals-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (btn.disabled) return;
          intervalsNodeId = btn.dataset.id;
          const name = btn.dataset.name || intervalsNodeId;
          intervalsTitle.textContent = `Intervals for ${name}`;
          if (intervalsReportingList) intervalsReportingList.textContent = 'Load to see dashboards this node posts results to. Enrolled automatically when added.';
          intervalsModalMsg.classList.add('hidden');
          intervalsModal.classList.remove('hidden');
          intervalsModal.setAttribute('aria-hidden', 'false');
        });
      });

      intervalsCloseBtn?.addEventListener('click', () => {
        intervalsModal?.classList.add('hidden');
        intervalsModal?.setAttribute('aria-hidden', 'true');
        intervalsNodeId = null;
      });

      intervalsModal?.addEventListener('click', (e) => {
        if (e.target === intervalsModal) intervalsCloseBtn?.click();
      });

      intervalsLoadBtn?.addEventListener('click', async () => {
        if (!intervalsNodeId) return;
        intervalsLoadBtn.disabled = true;
        showIntervalsMsg('Loading…', false);
        try {
          const r = await fetch(`/api/nodes/${encodeURIComponent(intervalsNodeId)}/config`, { credentials: 'same-origin' });
          const data = await r.json();
          if (!r.ok) {
            showIntervalsMsg(data.error || 'Failed to load', true);
            return;
          }
          intervalsSpeed.value = data.intervalMinutes ?? 360;
          if (intervalsReportingList) {
            const eps = data.reportEndpoints;
            if (Array.isArray(eps) && eps.length > 0) {
              intervalsReportingList.textContent = eps.map((e) => e.url).join(', ') || 'None';
            } else {
              intervalsReportingList.textContent = 'None (enrolled when you add the node to this dashboard).';
            }
          }
          showIntervalsMsg('Loaded.', false);
        } catch (err) {
          showIntervalsMsg(err.message || 'Request failed', true);
        } finally {
          intervalsLoadBtn.disabled = false;
        }
      });

      intervalsSaveBtn?.addEventListener('click', async () => {
        if (!intervalsNodeId) return;
        const intervalMinutes = parseInt(intervalsSpeed.value, 10);
        if (!Number.isFinite(intervalMinutes) || intervalMinutes < 1 || intervalMinutes > 1440) {
          showIntervalsMsg('Speed test interval must be 1–1440', true);
          return;
        }
        intervalsSaveBtn.disabled = true;
        showIntervalsMsg('Saving…', false);
        try {
          const r = await fetch(`/api/nodes/${encodeURIComponent(intervalsNodeId)}/config`, {
            method: 'PATCH',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ intervalMinutes }),
          });
          const data = await r.json();
          if (!r.ok) {
            showIntervalsMsg(data.error || 'Failed to save', true);
            return;
          }
          showIntervalsMsg('Saved. Speed test interval updated on node.', false);
        } catch (err) {
          showIntervalsMsg(err.message || 'Request failed', true);
        } finally {
          intervalsSaveBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
