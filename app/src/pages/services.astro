---
export const prerender = false;
import { getConnections, getServices } from '../lib/config-file.js';
import { getLatestResult } from '../lib/db.js';
import { startCron } from '../lib/cron.js';
import { getSabnzbdCurrentSpeedKbs } from '../lib/sabnzbd.js';

startCron();
const services = getServices();
const connections = getConnections();
const vpnServices = services.filter((service) => service.type === 'gluetun');
const downloadServices = services.filter((service) => service.type === 'sabnzbd');
const connectionIds = connections.map((connection) => connection.id);
const latest = getLatestResult();
const measuredDownloadMbps = latest?.download_mbps ?? null;
const connectionThroughputKbs = new Map<string, number>();
const throughputSamples = await Promise.all(
  downloadServices.map(async (service) => {
    if (!service.url || !service.apiKey) return null;
    try {
      const kbs = await getSabnzbdCurrentSpeedKbs(service.url, service.apiKey);
      if (kbs === null) return null;
      return { connectionId: service.connectionId || 'default', kbs };
    } catch {
      return null;
    }
  })
);
for (const sample of throughputSamples) {
  if (!sample) continue;
  connectionThroughputKbs.set(
    sample.connectionId,
    (connectionThroughputKbs.get(sample.connectionId) ?? 0) + sample.kbs
  );
}
const connectionStats = connections.map((connection) => {
  const members = services.filter((service) => (service.connectionId || 'default') === connection.id);
  const throughputKbs = connectionThroughputKbs.get(connection.id) ?? 0;
  const throughputMbps = throughputKbs / 125;
  const calculatedSpeedMbps = measuredDownloadMbps !== null ? measuredDownloadMbps + throughputMbps : null;
  return { ...connection, members, throughputMbps, calculatedSpeedMbps };
});

const addParam = Astro.url.searchParams.has('add') ? (Astro.url.searchParams.get('add') ?? '') : null;
const wizardType = addParam === 'sabnzbd' || addParam === 'gluetun' || addParam === 'connection' ? addParam : null;
const showWizard = addParam !== null;
const showTypeStep = showWizard && wizardType === null;
const showConnStep = showWizard && wizardType !== null;
const typeLabels: Record<string, string> = { sabnzbd: 'SABnzbd', gluetun: 'Gluetun', connection: 'Connection' };
const vpnNames = new Map(vpnServices.map((service) => [service.id, service.name]));
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Services – Speedarr</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
      header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: #1e293b; border-bottom: 1px solid #334155; }
      header h1 { margin: 0; font-size: 1.25rem; }
      nav a { color: #94a3b8; text-decoration: none; margin-right: 0.5rem; }
      nav a:hover { color: #fff; }
      nav button { background: #334155; color: #94a3b8; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; cursor: pointer; font-size: 0.9rem; }
      nav button:hover { background: #475569; color: #fff; }
      main { padding: 2rem; max-width: 980px; margin: 0 auto; }
      .section-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
      .section-header h2 { margin: 0; font-size: 1.1rem; }
      .section-sub { color: #94a3b8; font-size: 0.9rem; margin: 0 0 1rem; }
      .msg { padding: 0.5rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
      .msg.err { background: #7f1d1d; color: #fca5a5; }
      .msg.ok { background: #14532d; color: #86efac; }
      .msg.hidden { display: none; }
      .card { background: #1e293b; border-radius: 8px; padding: 1.25rem; margin-bottom: 1.5rem; }
      .connection-list { margin: 0; padding-left: 1.2rem; }
      .connection-list li { margin: 0.3rem 0; color: #cbd5e1; }
      .conn-id { font-size: 0.78rem; color: #94a3b8; margin-top: 0.2rem; }
      .badge-default { background: #0f766e; color: #99f6e4; margin-left: 0.4rem; }
      .services-table { width: 100%; border-collapse: collapse; }
      .services-table th { text-align: left; padding: 0.6rem 0.75rem; color: #94a3b8; font-weight: normal; font-size: 0.85rem; border-bottom: 1px solid #334155; white-space: nowrap; }
      .services-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #0f172a; vertical-align: middle; }
      .services-table tbody tr:hover { background: #0f172a; }
      .empty-state { text-align: center; padding: 2.5rem 1rem; color: #64748b; }
      .empty-state h3 { color: #94a3b8; margin-top: 0; }
      .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; }
      .badge-sabnzbd { background: #1d4ed8; color: #bfdbfe; }
      .badge-gluetun { background: #312e81; color: #c4b5fd; }
      .status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 0.35rem; background: #64748b; }
      .status-dot.ok { background: #22c55e; }
      .status-dot.err { background: #ef4444; }
      .status-dot.warn { background: #f59e0b; }
      .toggle-switch { position: relative; display: inline-block; width: 38px; height: 22px; }
      .toggle-switch input { opacity: 0; width: 0; height: 0; }
      .toggle-slider { position: absolute; cursor: pointer; inset: 0; background: #334155; border-radius: 22px; transition: .2s; }
      .toggle-slider:before { position: absolute; content: ""; width: 16px; height: 16px; left: 3px; bottom: 3px; background: #94a3b8; border-radius: 50%; transition: .2s; }
      input:checked + .toggle-slider { background: #3b82f6; }
      input:checked + .toggle-slider:before { transform: translateX(16px); background: #fff; }
      .limit-input { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.25rem 0.4rem; border-radius: 4px; width: 64px; text-align: center; }
      .limit-input:disabled { opacity: 0.4; }
      button.btn { background: #3b82f6; color: #fff; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; font-size: 0.9rem; }
      button.btn:hover { background: #2563eb; }
      button.btn-sm, a.btn-sm { background: #334155; color: #e2e8f0; border: none; padding: 0.3rem 0.6rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem; text-decoration: none; display: inline-block; }
      button.btn-sm:hover, a.btn-sm:hover { background: #475569; }
      button.btn-danger { background: transparent; color: #f87171; border: 1px solid #7f1d1d; padding: 0.3rem 0.6rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
      button.btn-danger:hover { background: #7f1d1d; }
      .wizard-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; display: flex; align-items: center; justify-content: center; padding: 1rem; }
      .wizard { background: #1e293b; border-radius: 12px; padding: 2rem; width: 100%; max-width: 480px; }
      .wizard-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.25rem; }
      .wizard-header h3 { margin: 0; }
      .wizard-close { color: #64748b; text-decoration: none; font-size: 1.25rem; line-height: 1; padding: 0.1rem 0.2rem; }
      .wizard-close:hover { color: #e2e8f0; }
      .wizard-step { font-size: 0.78rem; color: #475569; margin: 0 0 0.2rem; }
      .wizard-sub { color: #94a3b8; font-size: 0.9rem; margin: 0.25rem 0 1.5rem; }
      .type-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.5rem; }
      .type-card { background: #0f172a; border: 2px solid #334155; border-radius: 8px; padding: 1.25rem 1rem; text-decoration: none; color: #e2e8f0; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.4rem; transition: border-color .15s, background .15s; }
      .type-card:hover { border-color: #3b82f6; background: #1e3a5f; }
      .type-card-icon { width: 2.5rem; height: 2.5rem; border-radius: 999px; display: grid; place-items: center; background: #1e293b; font-weight: 700; }
      .wizard-form-row { margin-bottom: 0.75rem; }
      .wizard-form-row label { display: block; margin-bottom: 0.25rem; color: #94a3b8; font-size: 0.9rem; }
      .wizard-form-row input, .wizard-form-row select { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.4rem 0.6rem; border-radius: 4px; width: 100%; }
      .wizard-actions { display: flex; gap: 0.5rem; justify-content: space-between; align-items: center; margin-top: 1.25rem; }
      .icon-btn { background: #334155; color: #e2e8f0; border: none; width: 2rem; height: 2rem; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
      .icon-btn:hover { background: #475569; }
      .connection-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 120; display: flex; align-items: center; justify-content: center; padding: 1rem; }
      .connection-modal-overlay.hidden { display: none; }
      .connection-modal { background: #1e293b; border-radius: 12px; padding: 1.25rem; width: 100%; max-width: 420px; border: 1px solid #334155; }
      .connection-modal h3 { margin: 0 0 0.35rem; }
      .connection-modal p { margin: 0 0 1rem; color: #94a3b8; font-size: 0.9rem; }
      .connection-modal-row { margin-bottom: 0.8rem; }
      .connection-modal-row label { display: block; margin-bottom: 0.25rem; color: #94a3b8; font-size: 0.9rem; }
      .connection-modal-row input { width: 100%; background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.4rem 0.6rem; border-radius: 4px; }
      .connection-modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
      @media (max-width: 720px) {
        .services-table, .services-table thead, .services-table tbody, .services-table tr, .services-table th, .services-table td { display: block; }
        .services-table thead { display: none; }
        .services-table tr { padding: 0.75rem 0; border-bottom: 1px solid #0f172a; }
        .services-table td { padding: 0.25rem 0; border-bottom: none; }
        .type-cards { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <header>
      <h1>Speedarr</h1>
      <nav>
        <a href="/">Dashboard</a> · <a href="/history">History</a> · <a href="/nodes">Nodes</a> · <a href="/services">Services</a> · <a href="/settings">Settings</a>
        <form method="post" action="/api/auth/logout" style="display:inline; margin-left: 1rem;">
          <button type="submit">Sign out</button>
        </form>
      </nav>
    </header>
    <main>
      <div id="msg" class="msg hidden" role="status"></div>

      <div class="section-header">
        <div>
          <h2>Services</h2>
          <p class="section-sub">Services are grouped by connection. Throughput compensation is calculated per connection so active downloads do not understate line speed.</p>
        </div>
        <a href="?add" class="btn-sm">+ Add service</a>
      </div>

      <section class="card">
        <div class="section-header">
          <h2>Connections</h2>
        </div>
        <p class="section-sub">Calculated speed = latest speed test result + current download throughput on that connection.</p>
        {connectionStats.length === 0 ? (
          <p class="section-sub" style="margin:0;">No services configured yet.</p>
        ) : (
          <table class="services-table">
            <thead>
              <tr>
                <th>Connection</th>
                <th>Members</th>
                <th>Throughput</th>
                <th>Calculated speed</th>
                <th>Settings</th>
              </tr>
            </thead>
            <tbody>
              {connectionStats.map((connection) => (
                <tr>
                  <td>
                    <strong>{connection.name}</strong>
                    <div class="conn-id">
                      {connection.id}
                      {connection.id === 'default' && <span class="badge badge-default">default</span>}
                    </div>
                  </td>
                  <td>{connection.members.length > 0 ? connection.members.map((member) => member.name).join(', ') : '—'}</td>
                  <td>{connection.throughputMbps.toFixed(1)} Mbps</td>
                  <td>{connection.calculatedSpeedMbps !== null ? `${connection.calculatedSpeedMbps.toFixed(1)} Mbps` : 'n/a'}</td>
                  <td style="white-space:nowrap;">
                    <button
                      class="icon-btn connection-settings-btn"
                      data-id={connection.id}
                      data-name={connection.name}
                      data-is-default={connection.id === 'default' ? 'true' : 'false'}
                      aria-label={`Manage ${connection.name}`}
                      title={`Manage ${connection.name}`}
                    >
                      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M14.7 6.3a4 4 0 0 0 5 5l-9 9a2.1 2.1 0 0 1-3-3l9-9a4 4 0 0 0-2-2z"></path>
                        <path d="M16 3l5 5"></path>
                      </svg>
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </section>

      <section class="card">
        <div class="section-header">
          <h2>VPN services</h2>
        </div>
        {vpnServices.length === 0 ? (
          <div class="empty-state">
            <h3>No Gluetun services configured</h3>
            <p>Add a Gluetun service to monitor VPN status and attach it to download clients for kill-switch protection.</p>
          </div>
        ) : (
          <table class="services-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Connection</th>
                <th>Status</th>
                <th>Polling</th>
                <th>Enabled</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {vpnServices.map((service) => (
                <tr data-id={service.id} data-type={service.type}>
                  <td><strong>{service.name}</strong> <span class="badge badge-gluetun">gluetun</span></td>
                  <td>{service.connectionId || 'default'}</td>
                  <td><span class="status-dot" id={`status-${service.id}`}></span><span id={`status-label-${service.id}`}>—</span></td>
                  <td>{service.pollIntervalMinutes} min</td>
                  <td>
                    <label class="toggle-switch">
                      <input type="checkbox" class="enabled-toggle" data-id={service.id} checked={service.enabled} />
                      <span class="toggle-slider"></span>
                    </label>
                  </td>
                  <td style="white-space:nowrap; display:flex; gap:0.4rem; align-items:center;">
                    <a href={`/services/${service.id}`} class="btn-sm">Manage</a>
                    <button class="btn-danger delete-btn" data-id={service.id}>Delete</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </section>

      <section class="card">
        <div class="section-header">
          <h2>Download clients</h2>
        </div>
        {downloadServices.length === 0 ? (
          <div class="empty-state">
            <h3>No download clients configured</h3>
            <p>Add a download client to enable bandwidth schedules, speed-test-derived limits, and VPN-linked kill switch behavior.</p>
          </div>
        ) : (
          <table class="services-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Connection</th>
                <th>Status</th>
                <th>VPN</th>
                <th>Kill switch</th>
                <th>Speed limit</th>
                <th>Enabled</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {downloadServices.map((service) => (
                <tr data-id={service.id} data-type={service.type}>
                  <td><strong>{service.name}</strong> <span class="badge badge-sabnzbd">sabnzbd</span></td>
                  <td>{service.connectionId || 'default'}</td>
                  <td><span class="status-dot" id={`status-${service.id}`}></span><span id={`status-label-${service.id}`}>—</span></td>
                  <td>{service.vpnServiceId ? (vpnNames.get(service.vpnServiceId) ?? 'Missing') : '—'}</td>
                  <td>
                    <label class="toggle-switch">
                      <input type="checkbox" class="kill-switch-toggle" data-id={service.id} checked={service.killSwitchEnabled} />
                      <span class="toggle-slider"></span>
                    </label>
                  </td>
                  <td style="display:flex; align-items:center; gap:0.5rem;">
                    <label class="toggle-switch">
                      <input type="checkbox" class="speedtest-toggle" data-id={service.id} checked={service.speedtestLimitEnabled} />
                      <span class="toggle-slider"></span>
                    </label>
                    <input type="number" class="limit-input speedtest-percent" data-id={service.id} min="1" max="100" value={service.speedtestLimitPercent} disabled={!service.speedtestLimitEnabled} />
                  </td>
                  <td>
                    <label class="toggle-switch">
                      <input type="checkbox" class="enabled-toggle" data-id={service.id} checked={service.enabled} />
                      <span class="toggle-slider"></span>
                    </label>
                  </td>
                  <td style="white-space:nowrap; display:flex; gap:0.4rem; align-items:center;">
                    <a href={`/services/${service.id}`} class="btn-sm">Manage</a>
                    <button class="btn-danger delete-btn" data-id={service.id}>Delete</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </section>
    </main>

    {showWizard && (
      <div class="wizard-backdrop">
        <div class="wizard">
          {showTypeStep && (
            <div>
              <div class="wizard-header">
                <div>
                  <p class="wizard-step">Step 1 of 2</p>
                  <h3>Add a service</h3>
                </div>
                <a href="/services" class="wizard-close" aria-label="Close">x</a>
              </div>
              <p class="wizard-sub">Choose the service type to add.</p>
              <div class="type-cards">
                <a href="?add=sabnzbd" class="type-card">
                  <span class="type-card-icon">S</span>
                  <strong>SABnzbd</strong>
                  <p>Download client with schedules and speed-test throttling.</p>
                </a>
                <a href="?add=gluetun" class="type-card">
                  <span class="type-card-icon">G</span>
                  <strong>Gluetun</strong>
                  <p>VPN monitor that can be linked to one or more download clients.</p>
                </a>
                <a href="?add=connection" class="type-card">
                  <span class="type-card-icon">C</span>
                  <strong>Connection</strong>
                  <p>Logical line/group used for per-connection throughput calculations.</p>
                </a>
              </div>
              <a href="/services" class="btn-sm">Cancel</a>
            </div>
          )}
          {showConnStep && (
            <div>
              <div class="wizard-header">
                <div>
                  <p class="wizard-step">Step 2 of 2</p>
                  <h3>Connect {typeLabels[wizardType!]}</h3>
                </div>
                <a href="/services" class="wizard-close" aria-label="Close">x</a>
              </div>
              <p class="wizard-sub">Enter the connection details for this {typeLabels[wizardType!] } instance.</p>
              <form id="wizard-form">
                {wizardType === 'connection' ? (
                  <>
                    <div class="wizard-form-row">
                      <label for="w-connection-id">Connection ID</label>
                      <input type="text" id="w-connection-id" list="connection-options" placeholder="connection-a" autofocus />
                    </div>
                    <div class="wizard-form-row">
                      <label for="w-connection-name">Display name</label>
                      <input type="text" id="w-connection-name" placeholder="Connection A" />
                    </div>
                  </>
                ) : (
                  <>
                    <div class="wizard-form-row">
                      <label for="w-name">Name</label>
                      <input type="text" id="w-name" placeholder={wizardType === 'gluetun' ? 'Home VPN' : 'Main SABnzbd'} autofocus />
                    </div>
                    <div class="wizard-form-row">
                      <label for="w-url">URL</label>
                      <input type="text" id="w-url" placeholder={wizardType === 'gluetun' ? 'http://gluetun:8000' : 'http://sabnzbd:8080'} />
                    </div>
                    <div class="wizard-form-row">
                      <label for="w-connection">Connection ID</label>
                      <select id="w-connection">
                        {connections.map((connection) => (
                          <option value={connection.id} selected={connection.id === 'default'}>
                            {connection.name} ({connection.id})
                          </option>
                        ))}
                      </select>
                    </div>
                    <div class="wizard-form-row">
                      <label for="w-api-key">API key</label>
                      <input type="password" id="w-api-key" placeholder="API key" autocomplete="off" />
                    </div>
                    {wizardType === 'gluetun' && (
                      <div class="wizard-form-row">
                        <label for="w-poll">Polling interval (minutes)</label>
                        <input type="number" id="w-poll" min="1" max="1440" value="5" />
                      </div>
                    )}
                  </>
                )}
                <p id="wizard-error" style="color:#fca5a5; font-size:0.85rem; margin:0.5rem 0 0; display:none;"></p>
                <div class="wizard-actions">
                  <a href="?add" class="btn-sm">Back</a>
                  <button type="submit" class="btn" id="wizard-submit">{wizardType === 'connection' ? 'Add connection' : 'Add service'}</button>
                </div>
              </form>
            </div>
          )}
        </div>
      </div>
    )}
    <datalist id="connection-options">
      {connectionIds.map((connectionId) => (<option value={connectionId}></option>))}
    </datalist>
    <div id="connection-modal-overlay" class="connection-modal-overlay hidden">
      <div class="connection-modal">
        <h3>Connection settings</h3>
        <p>Rename the connection or delete it. Deleting reassigns attached services to <code>default</code>.</p>
        <div class="connection-modal-row">
          <label for="connection-modal-id">Connection ID</label>
          <input id="connection-modal-id" type="text" readonly />
        </div>
        <div class="connection-modal-row">
          <label for="connection-modal-name">Display name</label>
          <input id="connection-modal-name" type="text" />
        </div>
        <div class="connection-modal-actions">
          <button id="connection-modal-cancel" class="btn-sm">Cancel</button>
          <button id="connection-modal-delete" class="btn-danger">Delete</button>
          <button id="connection-modal-save" class="btn">Save</button>
        </div>
      </div>
    </div>

    <script define:vars={{ wizardType }}>
      const msgEl = document.getElementById('msg');
      function showMsg(text, isErr) {
        msgEl.classList.remove('hidden');
        msgEl.textContent = text;
        msgEl.className = 'msg ' + (isErr ? 'err' : 'ok');
      }

      const connectionModalOverlay = document.getElementById('connection-modal-overlay');
      const connectionModalId = document.getElementById('connection-modal-id');
      const connectionModalName = document.getElementById('connection-modal-name');
      const connectionModalSave = document.getElementById('connection-modal-save');
      const connectionModalDelete = document.getElementById('connection-modal-delete');
      const connectionModalCancel = document.getElementById('connection-modal-cancel');

      function closeConnectionModal() {
        connectionModalOverlay.classList.add('hidden');
      }

      document.querySelectorAll('.connection-settings-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const el = e.currentTarget;
          const id = el.dataset.id || '';
          const name = el.dataset.name || '';
          const isDefault = el.dataset.isDefault === 'true';
          connectionModalId.value = id;
          connectionModalName.value = name;
          connectionModalDelete.style.display = isDefault ? 'none' : '';
          connectionModalOverlay.classList.remove('hidden');
        });
      });

      connectionModalCancel?.addEventListener('click', (e) => {
        e.preventDefault();
        closeConnectionModal();
      });

      connectionModalOverlay?.addEventListener('click', (e) => {
        if (e.target === connectionModalOverlay) closeConnectionModal();
      });

      connectionModalSave?.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = connectionModalId.value.trim();
        const name = connectionModalName.value.trim();
        if (!name) {
          showMsg('Connection name is required', true);
          return;
        }
        const r = await fetch('/api/connections/' + id, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name }),
        });
        const data = await r.json();
        if (!r.ok) showMsg(data.error || 'Failed to rename connection', true);
        else window.location.reload();
      });

      connectionModalDelete?.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = connectionModalId.value.trim();
        if (!id || id === 'default') return;
        if (!confirm('Delete this connection? Services using it will be moved to default.')) return;
        const r = await fetch('/api/connections/' + id, { method: 'DELETE' });
        const data = await r.json();
        if (!r.ok) showMsg(data.error || 'Failed to delete connection', true);
        else window.location.reload();
      });

      document.querySelectorAll('tr[data-id]').forEach(async (row) => {
        const id = row.dataset.id;
        const type = row.dataset.type;
        const dot = document.getElementById('status-' + id);
        const label = document.getElementById('status-label-' + id);
        try {
          const r = await fetch('/api/services/' + id + '/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: '{}',
          });
          const data = await r.json();
          if (!dot || !label) return;
          if (!data.ok) {
            dot.className = 'status-dot err';
            label.textContent = data.error || 'Unreachable';
            return;
          }
          if (type === 'gluetun') {
            dot.className = 'status-dot ' + (data.status === 'running' ? 'ok' : 'warn');
            label.textContent = data.public_ip ? data.status + ' · ' + data.public_ip : data.status;
          } else {
            dot.className = 'status-dot ok';
            label.textContent = data.version ? 'v' + data.version : 'Connected';
          }
        } catch {
          if (dot) dot.className = 'status-dot err';
          if (label) label.textContent = 'Error';
        }
      });

      document.querySelectorAll('.enabled-toggle').forEach((el) => {
        el.addEventListener('change', async (e) => {
          const id = e.target.dataset.id;
          const enabled = e.target.checked;
          const r = await fetch('/api/services/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ enabled }),
          });
          if (!r.ok) {
            showMsg('Failed to save enabled state', true);
            e.target.checked = !enabled;
          }
        });
      });

      document.querySelectorAll('.kill-switch-toggle').forEach((el) => {
        el.addEventListener('change', async (e) => {
          const id = e.target.dataset.id;
          const enabled = e.target.checked;
          const r = await fetch('/api/services/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ killSwitchEnabled: enabled }),
          });
          if (!r.ok) {
            showMsg('Failed to save kill switch', true);
            e.target.checked = !enabled;
          }
        });
      });

      document.querySelectorAll('.speedtest-toggle').forEach((el) => {
        el.addEventListener('change', async (e) => {
          const id = e.target.dataset.id;
          const enabled = e.target.checked;
          const percentInput = document.querySelector('.speedtest-percent[data-id="' + id + '"]');
          if (percentInput) percentInput.disabled = !enabled;
          const r = await fetch('/api/services/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ speedtestLimitEnabled: enabled }),
          });
          if (!r.ok) {
            showMsg('Failed to save speed limit', true);
            e.target.checked = !enabled;
            if (percentInput) percentInput.disabled = enabled;
          }
        });
      });

      document.querySelectorAll('.speedtest-percent').forEach((el) => {
        el.addEventListener('change', async (e) => {
          const id = e.target.dataset.id;
          const percent = parseInt(e.target.value, 10);
          if (!percent || percent < 1 || percent > 100) return;
          const r = await fetch('/api/services/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ speedtestLimitPercent: percent }),
          });
          if (!r.ok) showMsg('Failed to save speed limit percent', true);
        });
      });

      document.querySelectorAll('.delete-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          const id = e.target.dataset.id;
          if (!confirm('Delete this service?')) return;
          const r = await fetch('/api/services/' + id, { method: 'DELETE' });
          if (r.ok) window.location.reload();
          else showMsg('Failed to delete', true);
        });
      });

      document.getElementById('wizard-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const errEl = document.getElementById('wizard-error');
        const submitBtn = document.getElementById('wizard-submit');
        errEl.style.display = 'none';
        submitBtn.disabled = true;
        submitBtn.textContent = wizardType === 'connection' ? 'Adding connection...' : 'Adding service...';
        try {
          if (wizardType === 'connection') {
            const connectionId = document.getElementById('w-connection-id').value.trim();
            const connectionName = document.getElementById('w-connection-name').value.trim() || connectionId;
            if (!connectionId) {
              errEl.textContent = 'Connection ID is required.';
              errEl.style.display = '';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Add connection';
              return;
            }
            const r = await fetch('/api/connections', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: connectionId, name: connectionName }),
            });
            const data = await r.json();
            if (r.ok) {
              window.location.href = '/services';
            } else {
              errEl.textContent = data.error || 'Failed to create connection.';
              errEl.style.display = '';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Add connection';
            }
          } else {
            const name = document.getElementById('w-name').value.trim();
            const url = document.getElementById('w-url').value.trim().replace(/\/$/, '');
            const connectionId = document.getElementById('w-connection').value.trim() || 'default';
            const apiKey = document.getElementById('w-api-key').value;
            const pollInput = document.getElementById('w-poll');
            const pollIntervalMinutes = pollInput ? (parseInt(pollInput.value, 10) || 5) : 5;
            if (!name) {
              errEl.textContent = 'Name is required.';
              errEl.style.display = '';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Add service';
              return;
            }
            const r = await fetch('/api/services', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name, type: wizardType, connectionId, url, apiKey, pollIntervalMinutes }),
            });
            const data = await r.json();
            if (r.ok) {
              window.location.href = '/services/' + data.service.id;
            } else {
              errEl.textContent = data.error || 'Failed to create service.';
              errEl.style.display = '';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Add service';
            }
          }
        } catch (err) {
          errEl.textContent = err.message || 'Request failed.';
          errEl.style.display = '';
          submitBtn.disabled = false;
          submitBtn.textContent = wizardType === 'connection' ? 'Add connection' : 'Add service';
        }
      });
    </script>
  </body>
</html>
