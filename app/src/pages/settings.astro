---
export const prerender = false;
import { getEffectiveConfig } from '../lib/config.js';
import { startCron } from '../lib/cron.js';

startCron();
const config = getEffectiveConfig();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Settings – Speedarr</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
      header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: #1e293b; border-bottom: 1px solid #334155; }
      header h1 { margin: 0; font-size: 1.25rem; }
      nav a { color: #94a3b8; text-decoration: none; margin-right: 0.5rem; }
      nav a:hover { color: #fff; }
      nav button { background: #334155; color: #94a3b8; border: none; padding: 0.35rem 0.75rem; border-radius: 4px; cursor: pointer; font-size: 0.9rem; }
      nav button:hover { background: #475569; color: #fff; }
      main { padding: 2rem; max-width: 620px; margin: 0 auto; }
      .form-section { background: #1e293b; padding: 1.25rem; border-radius: 8px; margin-bottom: 1.5rem; }
      .form-section h3 { margin-top: 0; }
      .form-section-desc { color: #94a3b8; font-size: 0.9rem; margin-bottom: 1rem; }
      .form-row { margin-bottom: 0.75rem; }
      .form-row label { display: block; margin-bottom: 0.25rem; color: #94a3b8; }
      .form-row input[type="number"] { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.4rem 0.6rem; border-radius: 4px; width: 100%; }
      .form-row .hint { font-size: 0.85rem; color: #64748b; margin-top: 0.25rem; }
      .msg { padding: 0.5rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
      .msg.err { background: #7f1d1d; color: #fca5a5; }
      .msg.ok { background: #14532d; color: #86efac; }
      .msg.hidden { display: none; }
      button.btn { background: #3b82f6; color: #fff; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; }
      button.btn:hover { background: #2563eb; }
      .inline-link { color: #93c5fd; text-decoration: none; }
      .inline-link:hover { color: #dbeafe; }
    </style>
  </head>
  <body>
    <header>
      <h1>Speedarr</h1>
      <nav>
        <a href="/">Dashboard</a> · <a href="/history">History</a> · <a href="/services">Services</a> · <a href="/settings">Settings</a>
        <form method="post" action="/api/auth/logout" style="display:inline; margin-left: 1rem;">
          <button type="submit">Sign out</button>
        </form>
      </nav>
    </header>
    <main>
      <h2>Settings</h2>
      <p class="form-section-desc">This page only controls history retention. Node/service-specific configuration is managed from <a class="inline-link" href="/services">Services</a>.</p>
      <div id="msg" class="msg hidden" role="status"></div>

      <form id="retention-form" class="form-section">
        <h3>History Retention</h3>
        <p class="form-section-desc">Old speed test results are pruned after each speed test cycle.</p>
        <div class="form-row">
          <label for="retention-days">Retention (days)</label>
          <input type="number" id="retention-days" name="retentionDays" min="0" value={config.retentionDays} />
          <p class="hint">0 = keep all history. Changes take effect on the next speed test (scheduled or manual).</p>
        </div>
        <button type="submit" class="btn">Save</button>
      </form>
    </main>
    <script>
      const msgEl = document.getElementById('msg');
      function showMsg(text, isErr) {
        msgEl.classList.remove('hidden');
        msgEl.textContent = text;
        msgEl.className = 'msg ' + (isErr ? 'err' : 'ok');
      }

      document.getElementById('retention-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const retentionRaw = (document.getElementById('retention-days')).value;
        const retentionDays = parseInt(retentionRaw, 10);
        if (!Number.isFinite(retentionDays) || retentionDays < 0) {
          showMsg('Retention days must be 0 or greater.', true);
          return;
        }
        try {
          const r = await fetch('/api/settings', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ SPEEDARR_RETENTION_DAYS: String(retentionDays) }),
          });
          const data = await r.json();
          if (!r.ok) showMsg(data.error || 'Failed to save retention.', true);
          else showMsg('Retention saved.', false);
        } catch (err) {
          showMsg((err && err.message) || 'Request failed', true);
        }
      });
    </script>
  </body>
</html>
